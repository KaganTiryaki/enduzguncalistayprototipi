# Supabase proje URL'si (Supabase dashboard → Project Settings → API)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Service Role Key (Project Settings → API → service_role)
# DİKKAT: Bu anahtar admin yetkisi verir. Public site'a / commit'e ASLA girmesin.
# Sadece bu yerel script kullanır, RLS bypass için.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# QR'ın kodladığı URL'in domain'i — basımdan önce KESİNLEŞMELİ.
# Örnek: https://mflfbc26.vercel.app  ya da  https://kalistay.mfl.k12.tr
BASE_URL=https://CHANGE-ME.vercel.app

# Üretilecek toplam kart sayısı (varsayılan 400)
CARD_COUNT=400
