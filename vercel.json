{
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "yemek.maltepefencalistay.org" }],
      "destination": "/giris",
      "permanent": false
    },
    {
      "source": "/tara.html",
      "has": [{ "type": "host", "value": "yemek.maltepefencalistay.org" }],
      "destination": "/gorevli",
      "permanent": false
    },
    {
      "source": "/panel.html",
      "has": [{ "type": "host", "value": "yemek.maltepefencalistay.org" }],
      "destination": "/admin",
      "permanent": false
    },
    {
      "source": "/index.html",
      "has": [{ "type": "host", "value": "yemek.maltepefencalistay.org" }],
      "destination": "/ogrenci",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/giris",
      "has": [{ "type": "host", "value": "yemek.maltepefencalistay.org" }],
      "destination": "/yemek/secim.html"
    },
    {
      "source": "/ogrenci",
      "has": [{ "type": "host", "value": "yemek.maltepefencalistay.org" }],
      "destination": "/yemek/index.html"
    },
    {
      "source": "/gorevli",
      "has": [{ "type": "host", "value": "yemek.maltepefencalistay.org" }],
      "destination": "/yemek/tara.html"
    },
    {
      "source": "/admin",
      "has": [{ "type": "host", "value": "yemek.maltepefencalistay.org" }],
      "destination": "/yemek/panel.html"
    },
    {
      "source": "/k/:kod",
      "has": [{ "type": "host", "value": "yemek.maltepefencalistay.org" }],
      "destination": "/yemek/index.html?kod=:kod"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "yemek.maltepefencalistay.org" }],
      "destination": "/yemek/:path*"
    },
    {
      "source": "/yemek/k/:kod",
      "destination": "/yemek/index.html?kod=:kod"
    }
  ]
}
