{
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "yemek.maltepefencalistay.org" }],
      "destination": "/giris",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/giris",
      "has": [{ "type": "host", "value": "yemek.maltepefencalistay.org" }],
      "destination": "/yemek/index.html"
    },
    {
      "source": "/k/:kod",
      "has": [{ "type": "host", "value": "yemek.maltepefencalistay.org" }],
      "destination": "/yemek/k.html?kod=:kod"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "yemek.maltepefencalistay.org" }],
      "destination": "/yemek/:path*"
    },
    {
      "source": "/yemek/k/:kod",
      "destination": "/yemek/k.html?kod=:kod"
    }
  ]
}
